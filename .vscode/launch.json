    {
      "name": "Backend: Test Server (Debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/runtime/examples/test_server/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/packages/runtime",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/runtime/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase:${workspaceFolder}/packages/runtime:${workspaceFolder}/packages/runtime/examples",
        "HOST": "127.0.0.1",
        "PORT": "8000",
        "ASTRA_JWT_SECRET": "dev-secret-for-testing"
      },
      "serverReadyAction": {
        "pattern": "Server running at: (https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "playground",
        "order": 1
      }
    },
    {
      "name": "Frontend: Playground Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/packages/playground",
      "serverReadyAction": {
        "pattern": "Local:.*(https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "playground",
        "order": 2
      }
    },
    {
      "name": "Backend: Content Research Workflow Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/runtime/examples/content_research_workflow/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/packages/runtime",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase"
      }
    },
    {
      "name": "Python: Example 3 - Tool Call Storage",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/storage/03_tool_cal.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase"
      }
    },
    {
      "name": "Memory: Example 1 - Memory Config",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/memory/01_memory_config.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase"
      }
    },
    {
      "name": "Memory: Example 2 - Context Window",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/memory/02_context_window.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Memory: Example 4 - Summarization",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/memory/03_summarization.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase"
      }
    },
    {
      "name": "Middleware: Example 1 - Input Middleware",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/middleware/01_input_middleware.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase"
      }
    },
    {
      "name": "Middleware: Example 2 - Output Middleware",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/middleware/02_output_middleware.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase"
      }
    },
    {
      "name": "Middleware: Example 3 - Combined Middleware",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/middleware/03_combined_middleware.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/runtime/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase:${workspaceFolder}/packages/runtime:${workspaceFolder}/packages/runtime/examples",
        "HOST": "127.0.0.1",
        "PORT": "8000",
        "ASTRA_JWT_SECRET": "dev-secret-for-testing"
      },
      "serverReadyAction": {
        "pattern": "Server running at: (https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "content-research",
        "order": 1
      }
    },
    {
      "name": "Backend: Teams Server (Debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/runtime/examples/teams/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/packages/runtime",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/runtime/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase:${workspaceFolder}/packages/runtime:${workspaceFolder}/packages/runtime/examples",
        "HOST": "127.0.0.1",
        "PORT": "8000",
        "ASTRA_JWT_SECRET": "dev-secret-for-testing",
        "MONGODB_URL": "mongodb://localhost:27017"
      },
      "serverReadyAction": {
        "pattern": "Uvicorn running on (https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "teams",
        "order": 1
      }
    },
    {
      "name": "Team: Research Team (04)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/packages/framework/examples/team/04_research_team.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/packages/framework/src:${workspaceFolder}/packages/observability:${workspaceFolder}/packages/memorybase"
      },
      "presentation": {
        "group": "team-examples",
        "order": 1
      }
    }
  ],
  "compounds": [
    {
      "name": "Teams: Server + Frontend Playground",
      "configurations": [
        "Backend: Teams Server (Debug)",
        "Frontend: Playground Dev Server"
      ],
      "stopAll": true,
      "presentation": {
        "group": "teams",
        "order": 0
      }
    },
    {
      "name": "Content Research: Workflow Server + Playground",
      "configurations": [
        "Backend: Content Research Workflow Server",
        "Frontend: Playground Dev Server"
      ],
      "stopAll": true,
      "presentation": {
        "group": "content-research",
        "order": 0
      }
    }
  ]
}
