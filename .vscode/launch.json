{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Enterprise Teams Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/astra/runtime/examples/enterprise_teams/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/astra/runtime/examples/enterprise_teams",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/astra/framework/src:${workspaceFolder}/astra/runtime/src:${workspaceFolder}/astra/runtime/examples/enterprise_teams",
        "HOST": "127.0.0.1",
        "PORT": "8000",
        "ASTRA_JWT_SECRET": "dev-secret-for-testing",
        "MONGODB_URL": "mongodb://localhost:27017"
      },
      "serverReadyAction": {
        "pattern": "Uvicorn running on (https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "enterprise-teams",
        "order": 1
      }
    },
    {
      "name": "Backend: Limca Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/astra/runtime/examples/limca/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/astra/runtime/examples/limca",
      "env": {
        "PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/astra/framework/src:${workspaceFolder}/astra/runtime/src:${workspaceFolder}/astra/runtime/examples/limca",
        "HOST": "127.0.0.1",
        "PORT": "8000",
        "ASTRA_JWT_SECRET": "dev-secret-for-testing",
        "MONGODB_URL": "mongodb://localhost:27017"
      },
      "serverReadyAction": {
        "pattern": "Uvicorn running on (https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "limca",
        "order": 1
      }
    },
    {
      "name": "Backend: Market Research Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/astra/runtime/examples/market_research/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/astra/runtime/examples/market_research",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/astra/framework/src:${workspaceFolder}/astra/runtime/src:${workspaceFolder}/astra/runtime:${workspaceFolder}/astra/runtime/examples/market_research",
        "HOST": "127.0.0.1",
        "PORT": "8000",
        "ASTRA_JWT_SECRET": "dev-secret-for-testing"
      },
      "serverReadyAction": {
        "pattern": "Uvicorn running on (https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "market-research",
        "order": 1
      }
    },
    {
      "name": "Backend: Investment Team Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "examples.investment_team.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/astra/runtime",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/astra/framework/src:${workspaceFolder}/astra/runtime/src:${workspaceFolder}/astra/observability/src:${workspaceFolder}/astra/runtime",
        "HOST": "127.0.0.1",
        "PORT": "8000",
        "ASTRA_JWT_SECRET": "dev-secret-for-testing",
        "MONGODB_URL": "mongodb://localhost:27017"
      },
      "serverReadyAction": {
        "pattern": "Uvicorn running on (https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "investment-team",
        "order": 1
      }
    },
    {
      "name": "Frontend: Playground Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "/opt/homebrew/bin/yarn",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/astra-playground-ui",
      "serverReadyAction": {
        "pattern": "Local:.*(https?://.*)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "presentation": {
        "group": "enterprise-teams",
        "order": 2
      }
    }
  ],
  "compounds": [
    {
      "name": "Enterprise Teams: Server + Frontend",
      "configurations": [
        "Backend: Enterprise Teams Server",
        "Frontend: Playground Dev Server"
      ],
      "stopAll": true,
      "presentation": {
        "group": "enterprise-teams",
        "order": 0
      }
    },
    {
      "name": "Market Research: Server + Frontend",
      "configurations": [
        "Backend: Market Research Server",
        "Frontend: Playground Dev Server"
      ],
      "stopAll": true,
      "presentation": {
        "group": "market-research",
        "order": 0
      }
    },
    {
      "name": "Limca: Server + Frontend",
      "configurations": [
        "Backend: Limca Server",
        "Frontend: Playground Dev Server"
      ],
      "stopAll": true,
      "presentation": {
        "group": "limca",
        "order": 0
      }
    },
    {
      "name": "Investment Team: Server + Frontend",
      "configurations": [
        "Backend: Investment Team Server",
        "Frontend: Playground Dev Server"
      ],
      "stopAll": true,
      "presentation": {
        "group": "investment-team",
        "order": 0
      }
    }
  ]
}