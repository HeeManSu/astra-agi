# Content Research Workflow - Environment Variables Example
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================================
# Database Configuration
# ============================================================================
# MongoDB connection URL
# Default: mongodb://localhost:27017
MONGODB_URL=mongodb://localhost:27017

# ============================================================================
# Model Configuration
# ============================================================================
# HuggingFace Remote Model URL (optional)
# If set, will use remote model server instead of local model
# Example: http://192.168.1.100:8000
# HUGGINGFACE_REMOTE_URL=

# Local Model ID (used when HUGGINGFACE_REMOTE_URL is not set)
# Default: Qwen/Qwen2.5-1.5B-Instruct
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# ============================================================================
# Server Configuration
# ============================================================================
# JWT secret for authentication
# Default: dev-secret-for-testing (change in production!)
ASTRA_JWT_SECRET=dev-secret-for-testing

# Server host
# Default: 127.0.0.1
HOST=127.0.0.1

# Server port
# Default: 8000
PORT=8000

# ============================================================================
# Optional API Keys
# ============================================================================
# News API key (optional)
# Required for get_recent_news tool to use NewsAPI
# Get your key at: https://newsapi.org/
# NEWS_API_KEY=
