"""Agents API endpoints."""

from typing import Optional

from fastapi import APIRouter, HTTPException
from pydantic import BaseModel
from sse_starlette.sse import EventSourceResponse

from app.agents import get_agent, list_agents

router = APIRouter()


class Message(BaseModel):
    """Chat message."""
    role: str
    content: str


class GenerateRequest(BaseModel):
    """Generate request payload."""
    messages: list[Message]
    thread_id: Optional[str] = None


class GenerateResponse(BaseModel):
    """Generate response payload."""
    content: str
    thread_id: Optional[str] = None


@router.get("")
async def list_all_agents():
    """List all registered agents."""
    agents = list_agents()
    return {"agents": [{"id": a.name, "name": a.name} for a in agents]}


@router.get("/{agent_id}")
async def get_agent_info(agent_id: str):
    """Get agent information."""
    agent = get_agent(agent_id)
    if not agent:
        raise HTTPException(status_code=404, detail=f"Agent '{agent_id}' not found")
    return {
        "id": agent.name,
        "name": agent.name,
        "instructions": agent.instructions[:100] + "..." if len(agent.instructions) > 100 else agent.instructions,
    }


@router.post("/{agent_id}/generate")
async def generate(agent_id: str, request: GenerateRequest):
    """Generate a response from an agent."""
    agent = get_agent(agent_id)
    if not agent:
        raise HTTPException(status_code=404, detail=f"Agent '{agent_id}' not found")
    
    # Get the last user message
    user_message = request.messages[-1].content if request.messages else ""
    
    # Invoke agent
    response = await agent.invoke(user_message, thread_id=request.thread_id)
    
    return GenerateResponse(
        content=response,
        thread_id=request.thread_id,
    )


@router.post("/{agent_id}/stream")
async def stream_generate(agent_id: str, request: GenerateRequest):
    """Stream a response from an agent using SSE."""
    agent = get_agent(agent_id)
    if not agent:
        raise HTTPException(status_code=404, detail=f"Agent '{agent_id}' not found")
    
    user_message = request.messages[-1].content if request.messages else ""
    
    async def event_generator():
        # For now, simulate streaming by yielding the full response
        # Replace with actual streaming when agent supports it
        response = await agent.invoke(user_message, thread_id=request.thread_id)
        for chunk in response.split():
            yield {"event": "chunk", "data": chunk + " "}
        yield {"event": "done", "data": ""}
    
    return EventSourceResponse(event_generator())
